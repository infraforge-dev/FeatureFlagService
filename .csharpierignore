# ============================================================
# .csharpierignore — Bandera
#
# CSharpier skips any path listed here.
# Syntax is identical to .gitignore.
# Paths are relative to the repo root.
# ============================================================

# ------------------------------------------------------------
# EF Core migrations
# These are auto-generated by `dotnet ef migrations add`.
# Reformatting them can break snapshot comparisons and cause
# spurious diffs on every migration add command.
# ------------------------------------------------------------
**/Migrations/

# ------------------------------------------------------------
# Build output
# Should never be in source control, but belt-and-suspenders.
# ------------------------------------------------------------
**/bin/
**/obj/

# ------------------------------------------------------------
# Generated code
# Any file with the .g.cs suffix is compiler-generated
# (e.g. source generators, Razor page codebehind).
# ------------------------------------------------------------
**/*.g.cs
**/*.generated.cs

# ------------------------------------------------------------
# NuGet package cache
# ------------------------------------------------------------
**/.nuget/

# ------------------------------------------------------------
# Rider / ReSharper scratch files
# ------------------------------------------------------------
**/_ReSharper*/
**/*.DotSettings.user

# ------------------------------------------------------------
# Node / frontend tooling (if ever added)
# ------------------------------------------------------------
**/node_modules/

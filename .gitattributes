# Normalize line endings to LF on commit regardless of developer OS.
# Prevents CSharpier format-check failures caused by CRLF files committed from Windows.

* text=auto eol=lf

*.cs    text eol=lf
*.csproj text eol=lf
*.sln   text eol=lf
*.slnx  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.xml   text eol=lf
*.props text eol=lf
*.targets text eol=lf

# Binaries — never normalize
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.pdf   binary
